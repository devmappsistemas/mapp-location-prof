# Configurações do Servidor
PORT=4049
NODE_ENV=development

# Configurações do Pool de Conexões
# TTL do cache de pools em milissegundos (padrão: 1800000 = 30 minutos)
POOL_TTL_MS=1800000

# Intervalo de limpeza de pools expirados em milissegundos (padrão: 300000 = 5 minutos)
CLEANUP_INTERVAL_MS=300000

# Limite de conexões por pool (padrão: 10)
CONNECTION_LIMIT=10

# Configurações de Retry
# Número máximo de tentativas em caso de falha temporária (padrão: 3)
MAX_RETRIES=3

# Delay inicial para retry em milissegundos (padrão: 1000 = 1 segundo)
RETRY_DELAY_MS=1000

# Nota: ACQUIRE_TIMEOUT e QUERY_TIMEOUT foram removidos pois não são
# opções válidas do mysql2. O mysql2 gerencia timeouts internamente.

# Fuso horário da conexão MySQL, ex: -03:00 (São Paulo), +00:00 (UTC)
DB_TIMEZONE=-03:00

# Exibir logs de webhook e fluxos relacionados (true/false)
DISPLAY_LOG_WEBHOOK=true

URL_AGENTE_N8N=https://n8n.appmapp.com.br/webhook/agente-treinavel-v2
# Runner de automações Kanban (disponível no mesmo .env / ponto de configuração do servidor ou painel web)
# Máximo de automações executadas em paralelo ao mesmo tempo (padrão: 10)
KANBAN_RUNNER_CONCURRENCY=10
# Timeout por automação em ms; 0 = desligado (padrão: 60000 = 60s)
KANBAN_RUNNER_TIMEOUT_MS=60000
# Registros por página na busca (padrão: 1000) - evita gargalo com muitas automações
KANBAN_RUNNER_PAGE_SIZE=1000

# Chave para POST /api/v1/profissionais-localizacoes (Bearer ou X-API-Key). Se vazia, rota fica aberta.
PROFISSIONAIS_LOCALIZACOES_API_KEY=35ec66525a33469df3c4d2140e5752ec0bf89cfa2658709e9699e745936caee7
PROFISSIONAIS_LOCALIZACOES_CONCURRENCY=3
PROFISSIONAIS_LOCALIZACOES_BATCH_SIZE=2
LOCATIONS_SOURCE_URL=http://localhost:5564/locations
LOCATIONS_FETCH_TIMEOUT_MS=5000

# Cooldown (s) entre pushes de confirmação (confirmarProfissional=S); rgLog menu Cheguei-Auto-PushCD. Padrão: 60.
CHEGUEI_CONFIRM_PUSH_COOLDOWN_SECONDS=60

# Redirecionamento webhook WhatsApp - node-mapp.mappsistemas.com + phone 956254904246156
WEBHOOK_REDIRECT_DOMAIN=node-mapp.mappsistemas.com
WEBHOOK_REDIRECT_PHONE_DEV=956254904246156
WEBHOOK_REDIRECT_URL_DEV=https://mapp-request.mototaxionline.srv.br/api/v1/webhook/whatsapp

# CDN direto no webhook (igual nodePdf)
CDN_DIRECT_UPLOAD_ENABLED=true
CDN_DIRECT_UPLOAD_FALLBACK_PHP=false
CDN_GCS_BUCKET=clientesmapptools
CDN_GCS_KEYFILE=C:\xampp\htdocs\nodePdf\arquivo-de-credenciais.json
CDN_GCS_PROJECT_ID=
CDN_GCS_PREFIX=whatsapp-midias
CDN_GCS_PUBLIC_BASE_URL=